{
  "openapi": "3.0.3",
  "info": {
    "title": "Demo App API",
    "version": "0.1.0"
  },
  "paths": {
    "/query": {
      "post": {
        "summary": "Query endpoint",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/QueryRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Query response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/QueryResponse"
                }
              }
            }
          }
        }
      }
    },
    "/mutation": {
      "post": {
        "summary": "Mutation endpoint",
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/MutationRequest"
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Mutation response",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/MutationResponse"
                }
              }
            }
          }
        }
      }
    }
  },
  "components": {
    "schemas": {
      "QueryRequest": {
        "type": "object",
        "properties": {
          "resources": {
            "type": "array",
            "items": {
              "type": "string",
              "enum": [
                "orders-query",
                "orders-mutation"
              ]
            }
          }
        }
      },
      "QueryResponse": {
        "type": "object",
        "properties": {
          "rows": {
            "type": "array",
            "items": {
              "type": "object"
            }
          }
        }
      },
      "MutationRequest": {
        "type": "object",
        "properties": {
          "action": {
            "type": "string"
          }
        }
      },
      "MutationResponse": {
        "type": "object",
        "properties": {
          "success": {
            "type": "boolean"
          }
        }
      }
    }
  }
}
