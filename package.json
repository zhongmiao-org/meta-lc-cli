{
  "name": "meta-lc-cli",
  "version": "0.1.0",
  "description": "Meta LowCode App DSL CLI",
  "type": "commonjs",
  "bin": {
    "meta-lc": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json && mkdir -p dist/__tests__/fixtures && cp -R src/__tests__/fixtures/. dist/__tests__/fixtures/",
    "test": "npm run build && node --test dist/__tests__/*.test.js",
    "lint": "npm run format:check",
    "format:check": "prettier --check .",
    "start": "node dist/cli.js"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "commander": "^12.1.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.17",
    "prettier": "^3.6.2",
    "typescript": "^5.9.3"
  }
}
